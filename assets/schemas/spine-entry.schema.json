{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Spine Entry",
  "description": "Schema for structured logbook entries in SPINE.md",
  "type": "object",
  "required": ["timestamp", "action_type", "action"],
  "properties": {
    "timestamp": { "type": "string" },
    "action_type": {
      "type": "string",
      "enum": ["INIT", "DATA_LOAD", "EXTRACT", "MODEL_TRAIN", "CALIBRATE", "FINDING", "REVIEW", "BUG_FIX", "DESIGN_CHANGE", "GATE_CHECK", "LITERATURE_SEARCH", "DATASET_DOWNLOAD"]
    },
    "action": { "type": "string", "minLength": 1, "maxLength": 500 },
    "input": { "type": ["string", "null"] },
    "output": { "type": ["string", "null"] },
    "gate_status": { "type": ["string", "null"] },
    "errors": { "type": ["string", "null"] },
    "next_action": { "type": ["string", "null"] }
  }
}